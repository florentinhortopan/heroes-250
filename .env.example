OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Quiz length (number of questions). Allowed range: 3..10. Default: 6.
# Override per-session by visiting /quiz?length=3 - the URL param wins
# and is remembered in sessionStorage until the browser tab closes.
VITE_QUIZ_LENGTH=6

# Number of answer buttons shown per question. Allowed range: 2..6. Default: 4.
# Override per-session by visiting /quiz?answers=3.
VITE_QUIZ_ANSWERS=4
